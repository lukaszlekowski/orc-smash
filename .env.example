# orc-smash — local agent/model profile
#
# Copy to `.env` and fill in. The tool's lowest-precedence runner defaults come from
# this file; the skill manifest defaults and per-run `--agent`/`--model` flags override.

# --- default runner (lowest precedence) ---
DEFAULT_AGENT=opencode
DEFAULT_MODEL=opencode/deepseek-v4-flash

# --- per-agent default models ---
# Used when a skill's runner is switched to that agent (changing an agent
# re-defaults its model to the value below).
OPENCODE_DEFAULT_MODEL=opencode/deepseek-v4-flash
CODEX_DEFAULT_MODEL=gpt-5.4-mini
CLAUDE_DEFAULT_MODEL=glm-4.7

# --- API keys (optional; only needed if calling a provider's HTTP endpoint
#     instead of its installed CLI binary) ---
# OPENCODE_API_KEY=
# CODEX_API_KEY=
# CLAUDE_API_KEY=
